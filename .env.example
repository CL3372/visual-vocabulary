# Copy this file to .env and fill in your values

# Pexels API key — get one free at https://www.pexels.com/api/
VITE_PEXELS_API_KEY=

# Stripe Payment Links — create at https://dashboard.stripe.com/payment-links
VITE_STRIPE_PAYMENT_LINK=
VITE_STRIPE_ANNUAL_LINK=

# Google Analytics 4 — get from https://analytics.google.com (format: G-XXXXXXXXXX)
# Leave blank to disable analytics
VITE_GA_ID=
